# Copie ce fichier en .env et renseigne tes propres valeurs.
# Le fichier .env ne doit JAMAIS être commité (il est listé dans .gitignore).

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Chemins (optionnels — valeurs par défaut sinon, voir config.py)
DOC_DIR=C:\Dev\DocRAG
CHROMA_DIR=C:\Dev\DocRAG\.chroma

# Paramètres RAG (optionnels)
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVER_K=5
RETRIEVER_FETCH_K=20

# Si tu ajoutes du tracing/observabilité plus tard (ex. Langfuse),
# applique le même principe : variables ici, jamais en dur dans le code.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
